{
  "title": "Deployments & Uptime",
  "uid": "deployments",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "timezone": "browser",
  "time": { "from": "now-7d", "to": "now" },
  "tags": ["predictive-alpha", "operations"],
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Uptime",
      "description": "Time since last restart.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "green", "value": 3600 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"predictive-alpha\"}",
          "legendFormat": "uptime"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Last Restart",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "process_start_time_seconds{job=\"predictive-alpha\"} * 1000",
          "legendFormat": "started"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Requests Served",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"predictive-alpha\"})",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "RPS vs p95 Latency (Scalability View)",
      "description": "Dual-axis: throughput on left, latency on right. Divergence signals scaling pressure.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "RPS" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "custom.axisPlacement", "value": "left" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95 Latency" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "RPS"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 Latency"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"predictive-alpha\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "process_virtual_memory_bytes{job=\"predictive-alpha\"}",
          "legendFormat": "Virtual"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Open File Descriptors",
      "description": "Proxy for active connections / open sockets. Rising trend indicates connection leak.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "process_open_fds{job=\"predictive-alpha\"}",
          "legendFormat": "open FDs"
        },
        {
          "expr": "process_max_fds{job=\"predictive-alpha\"}",
          "legendFormat": "max FDs"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Deployment Events (process restarts)",
      "description": "Each step-up in process_start_time_seconds indicates a new deployment or restart.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "custom": {
            "lineWidth": 2,
            "drawStyle": "line",
            "lineInterpolation": "stepAfter"
          }
        }
      },
      "targets": [
        {
          "expr": "process_start_time_seconds{job=\"predictive-alpha\"} * 1000",
          "legendFormat": "last start time"
        }
      ]
    }
  ]
}
