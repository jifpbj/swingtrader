{
  "title": "SLO Tracking",
  "uid": "slo-tracking",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["predictive-alpha", "slo"],
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability SLO — Target 99.5%",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job=\"predictive-alpha\"}[30d])",
          "legendFormat": "availability"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Latency SLO — p95 < 500ms",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate SLO — Target < 0.5%",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.003 },
              { "color": "red", "value": 0.005 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[30d])) / sum(rate(http_requests_total[30d]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Error Budget Remaining (Availability)",
      "description": "Percentage of 30-day error budget remaining. SLO = 99.5% availability.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "clamp_min(\n  (1 - (1 - avg_over_time(up{job=\"predictive-alpha\"}[30d])) / (1 - 0.995)) * 100,\n  0\n)",
          "legendFormat": "budget %"
        }
      ]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Error Budget Remaining (Error Rate)",
      "description": "Percentage of 30-day error budget remaining. SLO = < 0.5% 5xx errors.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "clamp_min(\n  (1 - (sum(rate(http_requests_total{status_code=~\"5..\"}[30d])) / sum(rate(http_requests_total[30d]))) / 0.005) * 100,\n  0\n)",
          "legendFormat": "budget %"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "SLO Burn Rate (error budget consumption speed)",
      "description": "Burn rate of 1× = consuming budget at exactly the SLO rate. 14.4× = budget exhausted in 1 hour.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "job:slo_burn_rate:1h",
          "legendFormat": "1h window"
        },
        {
          "expr": "job:slo_burn_rate:6h",
          "legendFormat": "6h window"
        },
        {
          "expr": "job:slo_burn_rate:3d",
          "legendFormat": "3d window"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "SLO Compliance — Error Rate over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.003 },
              { "color": "red", "value": 0.005 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "error rate (5m)"
        },
        {
          "expr": "0.005",
          "legendFormat": "SLO threshold (0.5%)"
        }
      ]
    },
    {
      "id": 8,
      "type": "alertlist",
      "title": "Active Alerts",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": ["alertname"],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 3,
        "stateFilter": {
          "error": true,
          "firing": true,
          "noData": false,
          "normal": false,
          "pending": true
        }
      }
    }
  ]
}
